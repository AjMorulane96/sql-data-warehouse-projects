--BRONZE QUERY FOR BRONZE LAYER , TO LOAD ONTO SILVER LAYER 
--WE NEED TO CHECK FOR DATA QUALITY ISSUES IN THE BRONZE LAYER 
--AND THEN PROCEED WITH LOADING THE DATA TO SILVER LAYER

-- check for nulls or buplicates in primary key
-- Expectation : no results

SELECT 
cst_id
FROM bronze.crm_cust_info 
GROUP BY cst_id
HAVING COUNT(*) > 1 or cst_id is null 

---Check fro unwanted spaces
-- Expectations is no results

SELECT cst_firstname
FROM bronze.crm_cust_info
WHERE cst_firstname != TRIM(cst_firstname) OR cst_lastname != TRIM(cst_lastname) OR cst_key != TRIM(cst_key) OR cst_material_status != TRIM(cst_material_status) OR cst_gndr != TRIM(cst_gndr)

-- Data Standardization & Consistancy check
-- Do we prefare Gender as abfreviation or full form ?
--if abbreviation then we can check for values other than M and F

SELECT DISTINCT cst_gndr
FROM bronze.crm_cust_info
WHERE cst_gndr NOT IN ('M','F') OR cst_gndr is null

-- Done with standardization of gender ,now we can check for material status
-- SAMe process as above

